{
  "manifest_version": 3,
  "name": "YouTube Shorts Meta",
  "version": "0.1.8",
  "description": "Show publish date and view count directly on YouTube Shorts pages.",
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
