{
  "manifest_version": 3,
  "name": "Shorts Lens",
  "version": "0.1.9",
  "description": "Show YouTube Shorts views and publish dates directly on the Shorts player.",
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
